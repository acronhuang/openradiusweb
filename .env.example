# OpenRadiusWeb Environment Configuration
# Copy this to .env.production and set ALL passwords before deploying.
#
# IMPORTANT: Never commit real passwords to version control.
#            Generate strong passwords for production use.

# ==========================================================
# REQUIRED — Set these before first deployment
# ==========================================================

# Database password (used by PostgreSQL and all services)
# Generate: openssl rand -base64 24
DB_PASSWORD=CHANGE_ME_DB_PASSWORD

# Redis password
# Generate: openssl rand -base64 24
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# JWT signing secret (used for API authentication tokens)
# Generate: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_JWT_SECRET

# ==========================================================
# Network & Service Configuration
# ==========================================================

# Network interface for device discovery (e.g., eth0, ens33, ens160)
SCAN_INTERFACE=eth0

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Service ports (defaults shown)
# ORW_WEB_PORT=8888
# ORW_API_PORT=8000
# RADIUS_AUTH_PORT=1812
# RADIUS_ACCT_PORT=1813
# RADIUS_COA_PORT=3799

# CORS origins (set to your server URL)
# CORS_ORIGINS=http://YOUR_SERVER_IP:8888

# Data retention (days)
# AUTH_LOG_RETENTION_DAYS=365
# EVENT_LOG_RETENTION_DAYS=180

# ==========================================================
# Optional
# ==========================================================

# Grafana admin password (only used when starting the monitoring profile:
#   docker compose -f docker-compose.prod.yml --profile monitoring up -d
# Falls back to 'admin' if unset; CHANGE THIS before exposing 127.0.0.1:3000
# beyond an SSH tunnel.
# GRAFANA_PASSWORD=CHANGE_ME_GRAFANA
