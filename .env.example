# OpenRadiusWeb Environment Configuration
# Copy this to .env.production and set ALL passwords before deploying.
#
# IMPORTANT: Never commit real passwords to version control.
#            Generate strong passwords for production use.

# ==========================================================
# REQUIRED — Set these before first deployment
# ==========================================================

# Database password (used by PostgreSQL and all services)
# Generate: openssl rand -base64 24
DB_PASSWORD=CHANGE_ME_DB_PASSWORD

# Redis password
# Generate: openssl rand -base64 24
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# JWT signing secret (used for API authentication tokens)
# Generate: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_JWT_SECRET

# Master secret + KDF salt for at-rest encryption of DB-stored secrets
# (LDAP bind passwords, RADIUS shared secrets, TLS private keys, etc.)
# AES-256-GCM with key derived via Argon2id from these two values.
#
# Generate BOTH together (run once per deployment):
#   python3 -c "import secrets; print('ORW_SECRET_MASTER=' + secrets.token_urlsafe(48)); print('ORW_SECRET_KDF_SALT=' + secrets.token_urlsafe(16))"
#
# WARNING: Losing these values makes EVERY encrypted DB column unreadable
# forever — there is no recovery. Back them up to a secure offline location
# (key escrow). Treat with the same care as DB_PASSWORD.
ORW_SECRET_MASTER=CHANGE_ME_SECRET_MASTER
ORW_SECRET_KDF_SALT=CHANGE_ME_SECRET_KDF_SALT

# Passphrase for encrypting backup tarballs at rest (scripts/backup.sh).
# Without this, backup.sh refuses to write a plaintext .tar.gz unless
# ORW_BACKUP_ALLOW_PLAINTEXT=1 is set explicitly. Backups contain
# .env.production (and therefore the master secret above) plus the
# decrypted server.key — anyone reading a plaintext backup gets keys
# to the kingdom.
#
# Generate one (independent of ORW_SECRET_MASTER — losing this only
# breaks restoring from existing backups, doesn't lose live data):
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
#
# Backup uses gpg --symmetric AES256. Encrypted output: *.tar.gz.gpg.
ORW_BACKUP_PASSPHRASE=CHANGE_ME_BACKUP_PASSPHRASE

# ==========================================================
# Network & Service Configuration
# ==========================================================

# Network interface for device discovery (e.g., eth0, ens33, ens160)
SCAN_INTERFACE=eth0

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Service ports (defaults shown)
# ORW_WEB_PORT=8888
# ORW_API_PORT=8000
# RADIUS_AUTH_PORT=1812
# RADIUS_ACCT_PORT=1813
# RADIUS_COA_PORT=3799

# CORS origins (set to your server URL)
# CORS_ORIGINS=http://YOUR_SERVER_IP:8888

# Data retention (days)
# AUTH_LOG_RETENTION_DAYS=365
# EVENT_LOG_RETENTION_DAYS=180

# ==========================================================
# Optional
# ==========================================================

# Grafana admin password (only used when starting the monitoring profile:
#   docker compose -f docker-compose.prod.yml --profile monitoring up -d
# Falls back to 'admin' if unset; CHANGE THIS before exposing 127.0.0.1:3000
# beyond an SSH tunnel.
# GRAFANA_PASSWORD=CHANGE_ME_GRAFANA
