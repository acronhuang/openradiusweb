# OpenRadiusWeb Generated Configuration - DO NOT EDIT MANUALLY
# Generated at: {{ generated_at }}
#
# Python module configuration (mods-available/python)
# Template: python.j2
#
# Configures rlm_python3 to load the OpenRadiusWeb (orw) RADIUS module.
# The orw module handles custom authorization, post-auth, and accounting
# logic via Python callbacks. Authentication itself is owned by rlm_ldap
# + eap, not orw.

python3 orw {
    module = orw

    python_path = "{{ python_path | default('/etc/freeradius/mods-config/python') }}"

{% if python_path_extra is defined and python_path_extra %}
    python_path = "${..python_path}:{{ python_path_extra }}"
{% endif %}

    #
    # Module function mappings
    # Each maps a FreeRADIUS processing section to a Python function
    #

    mod_instantiate = "${.module}"
    func_instantiate = instantiate

    mod_authorize = "${.module}"
    func_authorize = authorize

    # No mod_authenticate / func_authenticate: orw doesn't verify
    # credentials itself (rlm_ldap + eap own that path). The site
    # templates only call `orw` from authorize / post-auth / accounting.
    # rlm_python3 tries to LOAD every declared func at instantiation,
    # so declaring `func_authenticate = authenticate` here would crash
    # the module with `module 'orw' has no attribute 'authenticate'`
    # -- which is exactly the bug that surfaced once #49 made
    # _rlm_python3_available() actually return True.

    mod_post_auth = "${.module}"
    func_post_auth = post_auth

    mod_accounting = "${.module}"
    func_accounting = accounting

    mod_detach = "${.module}"
    func_detach = detach

{% if orw_config is defined and orw_config %}
    #
    # Configuration variables passed to the Python module
    #
    config {
{% for key, value in orw_config.items() %}
        {{ key }} = "{{ value }}"
{% endfor %}
    }
{% endif %}
}
